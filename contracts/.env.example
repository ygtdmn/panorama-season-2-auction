# Season 2 auction contracts env. Copy to .env (mainnet) or .env.sepolia (rehearsal)
# and fill in. All real env files are gitignored; never commit secrets.

# Broadcaster key for every lifecycle script. REQUIRED - Base.s.sol has no fallback
# key and refuses to run without it. Must be the owner of the Panorama NFT + mint
# controller (and the auction, once deployed).
PRIVATE_KEY=

# RPC + verification (foundry.toml wires these into rpc_endpoints/etherscan; the
# shell ops scripts build their RPC URL from API_KEY_ALCHEMY too, unless RPC_URL
# overrides it).
API_KEY_ALCHEMY=
API_KEY_ETHERSCAN=

# Core contracts the auction mints against.
PANORAMA_NFT=
PANORAMA_MINT_CONTROLLER=

# Deploy config (DeployAuction.s.sol / DeployAuctionSepolia.s.sol).
PANORAMA_AUCTION_OWNER=
# Reserve price in wei; must be >= 0.1 ETH (the contract's MIN_RESERVE_PRICE floor).
PANORAMA_AUCTION_RESERVE_PRICE=100000000000000000
# Minimum increment over the clearing floor, in bps (500 = 5%).
PANORAMA_AUCTION_MIN_INCREMENT_BPS=500
# Auction start as a unix timestamp; must be strictly in the future at deploy time.
PANORAMA_AUCTION_START=
# Duration in seconds (default 86400 = 24h; bounds 1h-30d). Adjustable after deploy
# until the first bid via setSchedule(start, duration).
PANORAMA_AUCTION_DURATION=86400
# Proceeds split 58%/42% to A/B at settlement.
PANORAMA_PAYOUT_A=
PANORAMA_PAYOUT_B=

# Filled in after deploy; pins every lifecycle script (Settle/Cancel/RefundAll).
# Obtain the codehash independently (e.g. cast keccak of the deployed runtime code),
# do not just copy what a script prints.
PANORAMA_AUCTION_ADDRESS=
PANORAMA_AUCTION_RUNTIME_CODEHASH=

# Batch sizes for settlement/refund loops (SettleAuctionAtomic / RefundAllAuction).
# finalize(45) ~= 8.1M gas; hostile refund receivers can add ~100k gas per winner.
PANORAMA_FINALIZE_BATCH=45
PANORAMA_REFUND_BATCH=45

# Optional: Discord webhook for scripts/monitor-auction.sh alerts.
DISCORD_WEBHOOK_URL=
