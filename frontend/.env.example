# Chain: 1 (mainnet), 11155111 (sepolia), or 31337 (local anvil). Drives wagmi + contract reads.
NEXT_PUBLIC_CHAIN_ID=1

# Authenticated HTTPS primary RPC. REQUIRED for production mainnet builds (env.ts fails the build
# without it when PANORAMA_PRODUCTION=1 or VERCEL_ENV=production). ws/wss is not accepted by the
# HTTP transport; plain http is allowed only for localhost/127.0.0.1 on chain 31337.
NEXT_PUBLIC_RPC_URL=

# WalletConnect project id. REQUIRED for production mainnet builds (mobile wallets).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# The deployed Season 2 auction contract.
NEXT_PUBLIC_PANORAMA_AUCTION_ADDRESS=

# Block the auction was deployed at; bounds the Won-event log scan for settlement standings.
NEXT_PUBLIC_AUCTION_DEPLOY_BLOCK=

# Set to 1 on the real production deployment (non-Vercel platforms) so build-time env
# validation arms. Vercel production deployments arm automatically via VERCEL_ENV.
PANORAMA_PRODUCTION=

# Panorama ERC721 (used for the "Contract" link) and ERC20 (informational).
NEXT_PUBLIC_PANORAMA_NFT_ADDRESS=0x435BD9CF72C278c9bAD9655732a6724469c6D9Ff
NEXT_PUBLIC_PANORAMA_ERC20_ADDRESS=

# CDN + explorer for hero paintings and tx/address links.
NEXT_PUBLIC_CDN_BASE_URL=https://cdn.panorama.garden
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://etherscan.io

# Public source repo shown in the footer (must be a PUBLIC repo to be reachable).
NEXT_PUBLIC_GITHUB_URL=https://github.com/ygtdmn/panorama

# Set to 1 to force the pages into in-memory demo mode (or visit /auction?demo=1).
NEXT_PUBLIC_AUCTION_DEMO=
